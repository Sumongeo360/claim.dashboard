<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Products Claim Report Dashboard</title>

<!-- Leaflet -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<!-- PapaParse & Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/papaparse@5.4.1/papaparse.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns"></script>

<style>
html, body {margin:0; padding:0; height:100%; font-family:Arial,sans-serif;}
#header {background:#1f2933; color:white; text-align:center; padding:12px; font-size:22px; font-weight:bold;}
#controls {display:flex; gap:8px; padding:8px; background:#fff; justify-content:center;}
select, button {font-size:16px; padding:4px 8px;}
#dashboard {display:flex; gap:10px; height:calc(100% - 130px); padding:10px;}
#map {flex:1; border-radius:6px; background:#e5e5e5;}
#chartArea {flex:1; background:#fff; padding:10px; border-radius:6px; display:flex; flex-direction:column;}
#summary {margin-top:8px;font-size:16px;font-weight:bold;color:#333;}
</style>
</head>

<body>
<div id="header">Products Claim Report Dashboard</div>

<div id="controls">
  <select id="insuranceFilter"><option value="">All Insurance</option></select>
  <select id="districtFilter"><option value="">All District</option></select>
  <select id="upazilaFilter"><option value="">All Upazila</option></select>
  <button id="resetBtn">Reset Filters</button>
  <button id="toggleLayerBtn">Satellite</button>
</div>

<div id="dashboard">
  <div id="map"></div>
  <div id="chartArea">
    <canvas id="tempChart"></canvas>
    <div id="summary"></div>
  </div>
</div>

<script>
// -------------------------
// CSV Data
const CSV_URL = "https://docs.google.com/spreadsheets/d/1lnnKF_oigj3TQl_N9BfIJJwviHktt3LzyW4UDMjHvxQ/gviz/tq?tqx=out:csv&gid=475032555";
let rawData = [], chartInstance;

// -------------------------
// DOM
const insuranceFilter = document.getElementById("insuranceFilter");
const districtFilter  = document.getElementById("districtFilter");
const upazilaFilter   = document.getElementById("upazilaFilter");
const resetBtn        = document.getElementById("resetBtn");
const summaryDiv      = document.getElementById("summary");
const toggleLayerBtn  = document.getElementById("toggleLayerBtn");

// -------------------------
// Leaflet Map
const map = L.map('map').setView([23.7, 90.3], 7);
const baseLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
const satelliteLayer = L.tileLayer('https://{s}.tile.openstreetmap.fr/hot/{z}/{x}/{y}.png'); // placeholder satellite
let currentLayer = "base";

// GeoJSON layers
let divLayer, distLayer, upazilaLayer;
let selectedFeature;

// -------------------------
// Load CSV
Papa.parse(CSV_URL, {
  download:true, header:true, skipEmptyLines:true,
  complete: function(results){
    rawData = results.data.map(r => ({
      insurance: r["Insurance Name"],
      date: new Date(r["Date"]),
      district: r["District"],
      upazila: r["Upazila"],
      trigger: parseFloat(r["Trigger"]),
      temp: parseFloat(r["Temperature(C)"])
    }));
    initFilters();
    updateDashboard();
  }
});

// -------------------------
// Filters
function initFilters(){
  const insurances = [...new Set(rawData.map(d=>d.insurance).filter(Boolean))].sort();
  const districts = [...new Set(rawData.map(d=>d.district).filter(Boolean))].sort();
  insuranceFilter.innerHTML = '<option value="">All Insurance</option>' + insurances.map(i=>`<option>${i}</option>`).join("");
  districtFilter.innerHTML  = '<option value="">All District</option>' + districts.map(d=>`<option>${d}</option>`).join("");
  insuranceFilter.onchange = updateDashboard;
  districtFilter.onchange  = ()=>{ updateUpazilas(); updateDashboard(); };
  upazilaFilter.onchange   = updateDashboard;
  resetBtn.onclick = ()=>{
    insuranceFilter.value=""; districtFilter.value=""; upazilaFilter.innerHTML='<option value="">All Upazila</option>';
    updateDashboard();
  };
  updateUpazilas();
}

function updateUpazilas(){
  const selectedDistrict = districtFilter.value;
  const upazilas = [...new Set(rawData.filter(d=>
    !selectedDistrict || d.district === selectedDistrict
  ).map(d=>d.upazila).filter(Boolean))].sort();
  upazilaFilter.innerHTML = '<option value="">All Upazila</option>' + upazilas.map(u=>`<option>${u}</option>`).join("");
}

// -------------------------
// Chart
function updateDashboard(){
  const insVal  = insuranceFilter.value;
  const distVal = districtFilter.value;
  const upaVal  = upazilaFilter.value;

  const filtered = rawData.filter(d =>
    (!insVal || d.insurance === insVal) &&
    (!distVal || d.district === distVal) &&
    (!upaVal || d.upazila === upaVal)
  ).sort((a,b)=>a.date - b.date);

  const labels = filtered.map(d => d.date);
  const temps  = filtered.map(d => d.temp);
  const triggers = filtered.map(d => (d.temp <= d.trigger) ? d.temp : null);

  const triggerDays = filtered.filter(d=>d.temp <= d.trigger).length;
  summaryDiv.textContent = "Total Trigger Days: " + triggerDays;

  if(chartInstance) chartInstance.destroy();
  chartInstance = new Chart(document.getElementById("tempChart").getContext("2d"), {
    type:'line',
    data:{labels, datasets:[
      {label:'Temperature (°C)', data:temps, borderColor:'blue', backgroundColor:'rgba(0,0,255,0.1)', tension:0.2},
      {label:'Trigger Points', data:triggers, borderColor:'red', pointRadius:6, showLine:false}
    ]},
    options:{scales:{x:{type:'time',time:{unit:'day'}},y:{title:{display:true,text:'Temperature (°C)'}}}}
  });
}

// -------------------------
// Load GeoJSON Layers
function loadGeoJSON(){
  fetch('gadm41_BGD_1.json').then(r=>r.json()).then(data=>{
    divLayer = L.geoJSON(data,{style:divStyle,onEachFeature:onEachDivision}).addTo(map);
  });
  fetch('gadm41_BGD_2.json').then(r=>r.json()).then(data=>{
    distLayer = L.geoJSON(data,{style:distStyle,onEachFeature:onEachDistrict});
  });
  fetch('gadm41_BGD_3.json').then(r=>r.json()).then(data=>{
    // optional district administrative polygons if needed
  });
  fetch('gadm41_BGD_4.json').then(r=>r.json()).then(data=>{
    upazilaLayer = L.geoJSON(data,{style:upazilaStyle,onEachFeature:onEachUpazila});
  });
}

// -------------------------
// Styles
function divStyle(){ return {color:'black', weight:2, fillColor:'#ffd', fillOpacity:0.4}; }
function distStyle(){ return {color:'black', weight:1, fillColor:'#cce', fillOpacity:0.4}; }
function upazilaStyle(){ return {color:'black', weight:1, fillColor:'#fdb', fillOpacity:0.4}; }

// -------------------------
// Click Handlers
function onEachDivision(feature, layer){
  layer.on('click', ()=>{
    if(selectedFeature) map.removeLayer(selectedFeature);
    selectedFeature = L.geoJSON(feature,{style:{color:'red',fillOpacity:0.5}}).addTo(map);
    map.fitBounds(layer.getBounds());
    districtFilter.value=""; upazilaFilter.innerHTML='<option value="">All Upazila</option>';
    updateDashboard();
  });
}

function onEachDistrict(feature, layer){
  layer.on('click', ()=>{
    if(selectedFeature) map.removeLayer(selectedFeature);
    selectedFeature = L.geoJSON(feature,{style:{color:'red',fillOpacity:0.5}}).addTo(map);
    map.fitBounds(layer.getBounds());
    upazilaFilter.innerHTML='<option value="">All Upazila</option>';
    updateUpazilas();
    updateDashboard();
  });
}

function onEachUpazila(feature, layer){
  layer.on('click', ()=>{
    if(selectedFeature) map.removeLayer(selectedFeature);
    selectedFeature = L.geoJSON(feature,{style:{color:'red',fillOpacity:0.5}}).addTo(map);
    map.fitBounds(layer.getBounds());
    upazilaFilter.value = feature.properties.NAME_4 || "";
    updateDashboard();
  });
}

// -------------------------
// Layer Toggle
toggleLayerBtn.onclick = ()=>{
  if(currentLayer === "base"){ map.removeLayer(baseLayer); satelliteLayer.addTo(map); currentLayer="sat"; toggleLayerBtn.textContent="Base"; }
  else { map.removeLayer(satelliteLayer); baseLayer.addTo(map); currentLayer="base"; toggleLayerBtn.textContent="Satellite"; }
}

// -------------------------
loadGeoJSON();

</script>
</body>
</html>
